from PPlay.window import *
from PPlay.sprite import *
from PPlay.keyboard import *

janela = Window(1000,600)
janela.set_title("Jogo")


player = Sprite("player.png")
player.x = janela.width/2 -100
player.y = 560 - player.height

bullet  = Sprite("bullet.png")

def jogar(diff):
 vetBullet = []

 while True:
    for i in range(len(vetBullet)-1):
         vetBullet[i].y -= (200 // diff) * janela.delta_time()

         if (vetBullet[i].y <= janela.height):
             vetBullet.pop()

         vetBullet[i].draw()

    if((janela.keyboard.key_pressed("right")) and (player.x <= janela.width - player.width)):
        player.x += (200 // diff) * janela.delta_time()

    if((janela.keyboard.key_pressed("left")) and (player.x >= 0)):
        player.x += (-200 // diff) * janela.delta_time()

    if(janela.keyboard.key_pressed("space")):
        bullet  = Sprite("bullet.png")
        bullet.x = player.x
        bullet.y = player.y
        vetBullet.append(bullet)

    janela.set_background_color("blue")

    if(janela.keyboard.key_pressed("esc")):
                break

    player.draw()
    janela.update()       


